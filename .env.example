# -------------------------------------------------------
# Jersey Minders — Configuration
# Copy this file to .env and fill in your values.
# -------------------------------------------------------

# Required: get a free key at https://the-odds-api.com
# Free tier = 500 requests/month (this app uses 1/day)
ODDS_API_KEY=your_odds_api_key_here

# Time to send the daily reminder (24-hour format, uses system/container timezone)
REMINDER_TIME=09:00


# -------------------------------------------------------
# Email Notification (via SMTP)
# -------------------------------------------------------
EMAIL_ENABLED=false

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Gmail: use an App Password (not your main password)
# https://support.google.com/accounts/answer/185833
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here

EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com   # can be different from sender


# -------------------------------------------------------
# ntfy.sh Push Notification (free, no account needed)
# Install the ntfy app on your phone, subscribe to your
# topic, and notifications arrive instantly.
# https://ntfy.sh
# -------------------------------------------------------
NTFY_ENABLED=false

# Pick any unique name — keep it private (it's your "password")
NTFY_TOPIC=my-secret-nhl-picks-topic-abc123


# -------------------------------------------------------
# Discord Notification (via Webhook)
# In Discord: channel settings → Integrations → Webhooks
# -------------------------------------------------------
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url_here
